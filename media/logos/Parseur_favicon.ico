        <a href="/zh/" @click="psrSetLang('zh-CN')" role="menuitem" id="menu-item-简体中文" class="group flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900">
          <picture><source sizes="(min-width: 1024px) 1024px, 100vw" srcset="/images/lang/cn.webp" type="image/webp"><img src="/images/lang/cn.webp" alt="简体中文 flag" height="16" width="16" srcset="/images/lang/cn.png" sizes="(min-width: 1024px) 1024px, 100vw"></picture>
          <span class="ml-1">简体中文</span>
        </a>
      
    
  </div>
</div>

      <a href="https://app.parseur.com/login" class="text-gray-900 hover:text-brand text-sm font-medium">
