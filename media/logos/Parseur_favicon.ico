  @keyframes orbitCard {
    from { transform: rotate(0deg) translateX(var(--orbit-r, 300px)); }
    to { transform: rotate(360deg) translateX(var(--orbit-r, 300px)); }
  }
  @keyframes counterOrbitCard {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
  }
  @keyframes pdfFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  .orbit-outer {
    --orbit-r: 300px;
    top: 50%; left: 50%;
    margin-left: -28px; margin-top: -28px;
    transform-origin: 28px 28px;
    animation: orbitCard 56s linear infinite;
  }
  .orbit-outer-counter {
    transform-origin: 28px 28px;
    animation: counterOrbitCard 56s linear infinite;
  }
  .orbit-inner {
    --orbit-r: 190px;
    top: 50%; left: 50%;
    margin-left: -24px; margin-top: -24px;
    transform-origin: 24px 24px;
    animation: orbitCard 36s linear infinite;
    animation-direction: reverse;
  }
  .orbit-inner-counter {
    transform-origin: 24px 24px;
    animation: counterOrbitCard 36s linear infinite;
    animation-direction: reverse;
  }

  /* Precomputed delays — outer (56s / 6 items) */
  .orbit-d-outer-1 { animation-delay: 0s; }
  .orbit-d-outer-2 { animation-delay: -9.33s; }
  .orbit-d-outer-3 { animation-delay: -18.67s; }
  .orbit-d-outer-4 { animation-delay: -28s; }
  .orbit-d-outer-5 { animation-delay: -37.33s; }
  .orbit-d-outer-6 { animation-delay: -46.67s; }

  /* Precomputed delays — inner reverse (36s / 4 items) */
  .orbit-d-inner-1 { animation-delay: -36s; }
  .orbit-d-inner-2 { animation-delay: -27s; }
  .orbit-d-inner-3 { animation-delay: -18s; }
  .orbit-d-inner-4 { animation-delay: -9s; }
</style>

