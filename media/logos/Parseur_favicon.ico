    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }
</style>

<div x-data="hiwSendAnimation({&quot;inboxLabel&quot;:&quot;Parseur Mailbox&quot;,&quot;sources&quot;:[{&quot;label&quot;:&quot;Email Forwarding&quot;,&quot;detail&quot;:&quot;invoice@acme.com → acme@in.parseur.com&quot;},{&quot;label&quot;:&quot;File Upload&quot;,&quot;detail&quot;:&quot;contract.pdf · 2.4 MB&quot;},{&quot;label&quot;:&quot;REST API&quot;,&quot;detail&quot;:&quot;POST /parser/:id/upload&quot;}]})" @hiw-active.window="if ($event.detail === 1) { clear(); start(); } else { clear(); }" class="w-full h-full p-6 flex flex-col justify-center gap-5 relative min-h-[420px]">
  <div class="absolute inset-0 opacity-[0.05] rounded-2xl" style="background-image: radial-gradient(circle, #0084C5 1px, transparent 1px); background-size: 24px 24px;"></div>

  
  <div class="relative z-10 flex flex-col gap-3">
    <template x-for="(src, i) in sources" :key="i">
      <div class="flex items-center gap-3 rounded-xl px-4 py-3 transition-all duration-300" :style="{
          background: activeSource === i ? 'rgba(0,132,197,0.18)' : received.includes(i) ? 'rgba(255,255,255,0.06)' : 'rgba(255,255,255,0.03)',
          border: activeSource === i ? '1px solid rgba(0,168,240,0.5)' : received.includes(i) ? '1px solid rgba(255,255,255,0.1)' : '1px solid rgba(255,255,255,0.06)',
          boxShadow: activeSource === i ? '0 0 18px rgba(0,132,197,0.2)' : 'none'
        }">
        <span :style="{ color: activeSource === i ? '#00a8f0' : received.includes(i) ? 'rgba(0,168,240,0.6)' : 'rgba(255,255,255,0.3)' }" x-html="src.icon"></span>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium" :style="{ color: activeSource === i ? '#fff' : received.includes(i) ? 'rgba(255,255,255,0.7)' : 'rgba(255,255,255,0.35)' }" x-text="src.label"></p>
          <p class="text-xs font-mono mt-0.5 truncate" :style="{ color: activeSource === i ? 'rgba(0,168,240,0.85)' : 'rgba(255,255,255,0.2)' }" x-text="src.detail"></p>
        </div>
        
        <template x-if="received.includes(i) &amp;&amp; activeSource !== i">
          <span class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center bg-brand/20">
            <svg width="9" height="9" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5 3.5-4" stroke="#00a8f0" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          </span>
        </template>
        
        <template x-if="activeSource === i">
          <span class="flex items-center gap-1">
            <span class="w-1 h-1 rounded-full bg-brand" style="animation: hiwBlink 0.7s ease-in-out 0s infinite"></span>
            <span class="w-1 h-1 rounded-full bg-brand" style="animation: hiwBlink 0.7s ease-in-out 0.15s infinite"></span>
            <span class="w-1 h-1 rounded-full bg-brand" style="animation: hiwBlink 0.7s ease-in-out 0.3s infinite"></span>
          </span>
        </template>
      </div>
    </template>
  </div>

  
  <div class="relative z-10 flex items-center gap-3 mt-1">
    <div class="flex-1 h-px" style="background: linear-gradient(90deg, rgba(0,132,197,0.4), rgba(0,132,197,0.1))"></div>
    <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
      <path d="M3 8h10M9 4l4 4-4 4" stroke="rgba(0,132,197,0.6)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
    <div class="flex items-center gap-2 rounded-xl px-4 py-2.5 transition-all duration-200" :style="{
        background: inboxPulse ? 'rgba(0,132,197,0.25)' : 'rgba(0,132,197,0.12)',
        border: inboxPulse ? '1px solid rgba(0,168,240,0.6)' : '1px solid rgba(0,132,197,0.25)',
        boxShadow: inboxPulse ? '0 0 20px rgba(0,132,197,0.35)' : 'none'
      }">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <path d="M22 12h-6l-2 3h-4l-2-3H2" stroke="#00a8f0" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M5.45 5.11L2 12v6a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-6l-3.45-6.89A2 2 0 0 0 16.76 4H7.24a2 2 0 0 0-1.79 1.11z" stroke="#00a8f0" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
      <span class="text-sm font-semibold text-[#00a8f0]">Parseur Mailbox</span>
      <template x-if="received.length > 0">
        <span class="text-xs font-bold text-white rounded-full w-5 h-5 flex items-center justify-center bg-brand leading-none" x-text="received.length"></span>
      </template>
    </div>
  </div>
</div>

<script>
function hiwSendAnimation(data) {
  const icons = ['fa-envelope', 'fa-file-arrow-up', 'fa-code'];
  const toIcon = (name) => `<i class="far ${name} text-lg"></i>`;
  return {
    activeSource: 0,
    received: [],
    inboxPulse: false,
    _timers: [],
    sources: data.sources.map((s, i) => ({ ...s, icon: toIcon(icons[i]) })),
    clear() { this._timers.forEach(clearTimeout); this._timers = []; },
    after(fn, ms) { this._timers.push(setTimeout(fn, ms)); },
    start() { this.cycle(); },
    cycle() {
      this.clear();
      const self = this;
      let src = 0;
      self.received = [];
      self.inboxPulse = false;

      const sendDoc = () => {
        self.activeSource = src;
        self.after(() => {
          self.activeSource = -1;
          self.inboxPulse = true;
          self.received = [...self.received, src];
          self.after(() => { self.inboxPulse = false; }, 400);
          src = (src + 1) % self.sources.length;
          if (src === 0) {
            self.after(() => window.dispatchEvent(new CustomEvent('hiw-done')), 1600);
          } else {
            self.after(sendDoc, 700);
          }
        }, 900);
      };

      self.after(sendDoc, 400);
    },
  };
}
</script>

              </div>
            
              <div class="absolute inset-0 transition-opacity duration-300" :class="active === 2 ? 'opacity-100 pointer-events-auto' : 'opacity-0 pointer-events-none'">
                <style>
  @keyframes hiwScanBeam {
    0%   { top: -40%; }
    100% { top: 100%; }
  }
  @keyframes hiwScanFast {
    0%   { top: -40%; }
    100% { top: 100%; }
  }
  @keyframes hiwFloatUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes hiwBlinkDot {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.3; }
  }
</style>

<div x-data="hiwAutomateAnimation({&quot;cardTitle&quot;:&quot;Extracted Data&quot;,&quot;deliveredLabel&quot;:&quot;Delivered&quot;,&quot;sendingLabel&quot;:&quot;Sending&quot;,&quot;fields&quot;:[{&quot;key&quot;:&quot;Invoice #&quot;,&quot;value&quot;:&quot;INV-20251&quot;},{&quot;key&quot;:&quot;Company&quot;,&quot;value&quot;:&quot;Acme Corp&quot;},{&quot;key&quot;:&quot;Amount&quot;,&quot;value&quot;:&quot;$4,200.00&quot;},{&quot;key&quot;:&quot;Due Date&quot;,&quot;value&quot;:&quot;Apr 1, 2025&quot;},{&quot;key&quot;:&quot;Line Items&quot;,&quot;value&quot;:&quot;3 rows&quot;}]})" @hiw-active.window="if ($event.detail === 2) { clear(); start(); } else { clear(); }" class="w-full h-full p-6 flex flex-col gap-4 relative min-h-[420px]">
  <div class="absolute inset-0 opacity-[0.05] rounded-2xl" style="background-image: radial-gradient(circle, #0084C5 1px, transparent 1px); background-size: 24px 24px;"></div>

  
  <div class="relative z-10 rounded-xl overflow-hidden border border-brand/30 bg-[rgba(0,56,84,0.6)]">
    <div class="flex items-center gap-2 px-4 py-2.5 border-b border-white/10">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="#0084C5" stroke-width="2"></path>
        <polyline points="14,2 14,8 20,8" stroke="#0084C5" stroke-width="2"></polyline>
      </svg>
      <span class="text-xs font-bold text-gray-100 uppercase tracking-widest">Extracted Data</span>
      <span class="ml-auto flex items-center gap-1">
        <span class="w-1 h-1 rounded-full bg-brand" style="animation: hiwBlinkDot 0.7s ease-in-out 0s infinite"></span>
        <span class="w-1 h-1 rounded-full bg-brand" style="animation: hiwBlinkDot 0.7s ease-in-out 0.15s infinite"></span>
        <span class="w-1 h-1 rounded-full bg-brand" style="animation: hiwBlinkDot 0.7s ease-in-out 0.3s infinite"></span>
      </span>
    </div>
    <div class="flex flex-col divide-y divide-white/10">
      <template x-for="(f, i) in fields" :key="i">
        <div class="flex items-center justify-between px-4 py-2.5" :style="{
            opacity: visibleFields.includes(i) ? 1 : 0,
            transform: visibleFields.includes(i) ? 'translateX(0)' : 'translateX(-8px)',
            transition: 'opacity 0.3s ease, transform 0.3s ease'
          }">
          <span class="text-xs text-gray-100 font-medium w-20 flex-shrink-0" x-text="f.key"></span>
          <span class="flex-1 h-px mx-3" :style="{ background: visibleFields.includes(i) ? 'rgba(0,132,197,0.25)' : 'transparent', transition: 'background 0.3s ease' }"></span>
          <span class="text-xs font-bold text-gray-100 font-mono" x-text="f.value"></span>
        </div>
      </template>
    </div>
  </div>

  
  <div class="relative z-10 flex flex-col items-center gap-2">
    <div class="relative w-0.5 h-8 overflow-hidden bg-brand/[15%]">
      <div class="absolute w-full rounded-full" style="height: 40%" :style="{
          background: 'linear-gradient(180deg, transparent, #0084C5, transparent)',
          animation: firing ? 'hiwScanFast 0.6s linear forwards' : 'hiwScanBeam 1.8s linear infinite'
        }"></div>
    </div>

    
    <div class="flex items-center gap-2.5 rounded-xl px-4 py-2.5 w-full transition-all duration-300" :style="{
        background: (firing || sent) ? destinations[wave].color + '22' : 'rgba(255,255,255,0.05)',
        border: (firing || sent) ? '1px solid ' + destinations[wave].color + '66' : '1px solid rgba(255,255,255,0.1)',
        boxShadow: firing ? '0 0 24px ' + destinations[wave].color + '44' : 'none'
      }">
      <span :style="{ color: (firing || sent) ? destinations[wave].color : 'rgba(255,255,255,0.3)', transition: 'color 0.3s ease' }" x-html="destinations[wave].icon"></span>
      <span class="text-base font-bold transition-colors duration-300" :style="{ color: (firing || sent) ? '#fff' : 'rgba(255,255,255,0.4)' }" x-text="destinations[wave].label"></span>
      <template x-if="sent &amp;&amp; !firing">
        <span class="ml-auto flex items-center gap-1 text-sm font-bold text-white" style="animation: hiwFloatUp 0.3s ease both">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 5l2.5 2.5 3.5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
          Delivered
        </span>
      </template>
      <template x-if="firing">
        <span class="ml-auto text-sm font-bold text-white" style="animation: hiwBlinkDot 0.3s ease-in-out infinite">Sending…</span>
      </template>
    </div>

    
    <div class="flex gap-2 mt-1">
      <template x-if="wave !== 0">
        <div class="flex items-center gap-1.5 rounded-lg px-3 py-1.5 bg-white/[4%] border border-white/[7%]">
          <span class="text-white/20" x-html="destinations[0].icon"></span>
          <span class="text-sm font-medium text-white/30" x-text="destinations[0].label"></span>
        </div>
      </template>
      <template x-if="wave !== 1">
        <div class="flex items-center gap-1.5 rounded-lg px-3 py-1.5 bg-white/[4%] border border-white/[7%]">
          <span class="text-white/20" x-html="destinations[1].icon"></span>
          <span class="text-sm font-medium text-white/30" x-text="destinations[1].label"></span>
        </div>
      </template>
      <template x-if="wave !== 2">
        <div class="flex items-center gap-1.5 rounded-lg px-3 py-1.5 bg-white/[4%] border border-white/[7%]">
          <span class="text-white/20" x-html="destinations[2].icon"></span>
          <span class="text-sm font-medium text-white/30" x-text="destinations[2].label"></span>
        </div>
      </template>
    </div>
  </div>
</div>

<script>
function hiwAutomateAnimation(data) {
  const toIcon = (name) => `<i class="far ${name} text-base"></i>`;
  const DESTINATIONS = [
    { label: 'Google Sheets', color: '#0F9D58', icon: toIcon('fa-table') },
    { label: 'Zapier',        color: '#FF4A00', icon: toIcon('fa-bolt') },
    { label: 'Webhook',       color: '#f3f4f6', icon: toIcon('fa-link') },
  ];
  const WAVES = [
    { dest: 0, fields: [0, 1, 2, 3] },
    { dest: 1, fields: [0, 1, 2, 3, 4] },
    { dest: 2, fields: [0, 1, 2, 3, 4] },
  ];
  return {
    wave: 0,
    visibleFields: [],
    firing: false,
    sent: false,
    _timers: [],
    fields: data.fields,
    destinations: DESTINATIONS,
    clear() { this._timers.forEach(clearTimeout); this._timers = []; },
    after(fn, ms) { this._timers.push(setTimeout(fn, ms)); },
    start() { this.runWave(0); },
    runWave(waveIdx) {
      const self = this;
      const w = WAVES[waveIdx % WAVES.length];
      self.wave = waveIdx % WAVES.length;
      self.visibleFields = [];
      self.firing = false;
      self.sent = false;

      w.fields.forEach((fi, order) => {
        self.after(() => {
          self.visibleFields = [...self.visibleFields, fi];
        }, 300 + order * 220);
      });

      const fireDelay = 300 + w.fields.length * 220 + 300;
      self.after(() => {
        self.firing = true;
        self.after(() => {
          self.firing = false;
          self.sent = true;
          const nextIdx = waveIdx + 1;
          if (nextIdx >= WAVES.length) {
            self.after(() => window.dispatchEvent(new CustomEvent('hiw-done')), 1200);
          } else {
            self.after(() => self.runWave(nextIdx), 1200);
          }
        }, 700);
      }, fireDelay);
    },
  };
}
</script>

