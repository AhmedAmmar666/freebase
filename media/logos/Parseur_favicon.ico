    <main>
      <div class="mt-16 sm:mt-20">
  
  <section class="mx-auto flex max-w-6xl flex-col items-center gap-8 px-4 py-10 md:px-10 md:py-16 lg:flex-row lg:gap-14 lg:py-10" style="min-height: calc(86vh - 73px)">
    <div class="w-full min-w-0 flex-1 text-left md:text-center lg:text-left">
      <h1 class="mb-6 text-5xl font-bold leading-tight md:text-6xl lg:text-7xl">Documents in.<br> Clean data out.<br> <span class="text-brand">Automatically.</span>
</h1>
      <div class="mb-8 max-w-lg text-base leading-relaxed text-navy/65 md:mx-auto md:text-xl lg:mx-0">Go live in minutes. AI data extraction that turns PDFs, emails, and scans into production data with no training, built for privacy and scale.
</div>
      <div class="flex items-center gap-4 md:justify-center lg:justify-start">
        
<a href="https://app.parseur.com/signup" x-init="add_utm($el, 'hero-cta')" class="bg-brand text-white px-6 py-3 rounded-md text-sm md:text-base font-semibold shadow-md transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[3px] hover:shadow-[0_8px_20px_rgba(0,132,197,0.45)]">Upload document</a>

        
          
<a href="/book-demo" class="bg-white text-navy px-6 py-3 rounded-md text-sm md:text-base font-semibold border border-navy/20 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-[3px] hover:border-navy/50 hover:shadow-[0_8px_20px_rgba(0,56,84,0.15)]">Book a demo</a>

        
      </div>
    </div>
    <div class="relative flex min-h-72 w-full max-w-96 items-center justify-center rounded-2xl bg-navy p-8 md:mx-auto md:min-h-96 lg:mx-0 lg:w-96 lg:flex-shrink-0">
      

<style>
  @keyframes docDropIn {
    0% {
      transform: translate(-50%, -160px) scale(1);
    }
    100% {
      transform: translate(-50%, 0) scale(1.4);
    }
  }
  @keyframes boxPulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(0,132,197,0);
    }
    50% {
      box-shadow: 0 0 20px 4px rgba(0,132,197,0.25);
    }
  }
  @keyframes processorScan {
    0% {
      top: 0;
    }
    100% {
      top: 100%;
    }
  }
  @keyframes heroBlink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }
  @keyframes dataCrossfade {
    0% {
      opacity: 0;
      transform: translateY(6px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @keyframes dataSlideOut {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    100% {
      transform: translateY(160px);
      opacity: 0;
    }
  }
  @keyframes exportPipeBeam {
    0% {
      top: -40%;
    }
    100% {
      top: 100%;
    }
  }
  @keyframes exportStatusIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<div x-data="heroAnimation({&quot;counterLabel&quot;:&quot;processed&quot;,&quot;fieldLabels&quot;:[&quot;Company&quot;,&quot;Reference&quot;,&quot;Amount&quot;,&quot;Date&quot;],&quot;statusLabels&quot;:{&quot;sending&quot;:&quot;Sending&quot;,&quot;delivered&quot;:&quot;Delivered&quot;,&quot;downloading&quot;:&quot;Downloading&quot;,&quot;downloaded&quot;:&quot;Downloaded&quot;},&quot;destinationKinds&quot;:{&quot;spreadsheet&quot;:&quot;Spreadsheet&quot;,&quot;automation&quot;:&quot;Automation&quot;,&quot;download&quot;:&quot;Download&quot;,&quot;customApp&quot;:&quot;Custom App&quot;}})" x-init="start()" style="width:340px;height:470px;display:flex;flex-direction:column;align-items:center;flex-shrink:0">

  
  <div style="height:104px;width:100%;position:relative;overflow:hidden">
    
    <div style="position:absolute;bottom:2px;left:8px;right:8px;height:12px;
      border-left:2px solid rgba(255,255,255,0.1);
      border-right:2px solid rgba(255,255,255,0.1);
      border-bottom:1px solid rgba(255,255,255,0.05);
      border-radius:0 0 2px 2px"></div>
    
    <div style="position:absolute;bottom:0;left:0;top:0;width:24px;
      background:linear-gradient(90deg, var(--color-navy), transparent);
      z-index:10;pointer-events:none"></div>

    
    <div :style="{
      position:'absolute', bottom:'0', left:'14px',
      transform: 'translateX(' + beltOffset + 'px)',
      transition: beltTransition
    }">
      
      <div style="position:absolute;bottom:4px;left:-2px;height:6px;width:800px;
        border-radius:3px;
        background:repeating-linear-gradient(90deg, rgba(255,255,255,0.07) 0px, rgba(255,255,255,0.07) 8px, rgba(255,255,255,0.025) 8px, rgba(255,255,255,0.025) 20px);
        border:1px solid rgba(255,255,255,0.08)"></div>
      
      <div style="display:flex;align-items:flex-end;gap:16px;padding-bottom:12px">
        <template x-for="(doc, i) in beltDocs" :key="doc.id">
          <div :style="{
          width: '64px',
          flexShrink: 0,
          visibility: (droppingDoc &amp;&amp; doc.id === droppingDoc.id) ? 'hidden' : 'visible',
          opacity: Math.max(0.15, 1 - i * 0.1),
          transition: 'opacity 0.8s ease'
        }">
            <div :style="{
            background: '#fff',
            borderRadius: '3px',
            boxShadow: '0 2px 8px rgba(0,0,0,0.15), inset 0 0 0 1px ' + doc.border,
            overflow: 'hidden',
            position: 'relative',
            height: '90px'
          }">
              <div :style="{ height:'3px', background: doc.color }"></div>
              
              <div style="position:absolute;top:3px;right:0;width:0;height:0;border-style:solid;border-width:0 8px 8px 0;border-color:transparent rgba(0,132,197,0.08) transparent transparent"></div>
              <div style="padding:4px 4px 5px">
                
                <div :style="{
                fontSize: '8px',
                fontWeight: 700,
                color: doc.color,
                whiteSpace: 'nowrap',
                overflow: 'hidden',
                textOverflow: 'ellipsis',
                marginBottom: '3px',
                lineHeight: '7px'
              }" x-text="doc.values[0]"></div>
                
                <div style="display:flex;flex-direction:column;gap:2px" x-html="doc.skeleton"></div>
              </div>
            </div>
          </div>
        </template>
      </div>
    </div>
  </div>

  
  <div style="display:flex;justify-content:center;align-items:center;height:24px">
    <div style="width:2px;height:100%;background:rgba(255,255,255,0.14)"></div>
  </div>

  
  <div :style="{
    width:'100%', flex:1, borderRadius:'14px', padding:'10px 14px 22px',
    transition:'background 0.4s, border-color 0.4s',
    background: processorActive
      ? 'linear-gradient(135deg, rgba(0,56,84,0.95), rgba(0,20,42,0.98))'
      : 'rgba(255,255,255,0.04)',
    border:'1.5px solid',
    borderColor: processorDoc ? 'rgba(0,132,197,0.7)' : 'rgba(255,255,255,0.1)',
    animation: processorActive ? 'boxPulse 1s ease-in-out infinite' : 'none',
    display:'flex', flexDirection:'column',
    position:'relative'
  }">
    
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      
      <div :style="{ display:'flex', gap:'4px', width:'60px', visibility: processorActive ? 'visible' : 'hidden' }">
        <div style="width:5px;height:5px;border-radius:50%;background:#0084C5;box-shadow:0 0 6px rgba(0,132,197,1);animation:heroBlink 0.7s ease-in-out 0s infinite"></div>
        <div style="width:5px;height:5px;border-radius:50%;background:#0084C5;box-shadow:0 0 6px rgba(0,132,197,1);animation:heroBlink 0.7s ease-in-out 0.18s infinite"></div>
        <div style="width:5px;height:5px;border-radius:50%;background:#0084C5;box-shadow:0 0 6px rgba(0,132,197,1);animation:heroBlink 0.7s ease-in-out 0.36s infinite"></div>
      </div>
      
      <svg width="22" height="22" viewBox="0 0 32 36" fill="none" :style="processorActive
          ? { filter: 'drop-shadow(0 0 8px rgba(0,132,197,0.8))', transition:'filter 0.4s' }
          : { transition:'filter 0.4s' }">
        <g :fill="processorActive ? '#0084C5' : 'rgba(255,255,255,0.2)'">
          <path d="M5.406 5.742L5.63 5.779l.97.559.969.559.97.559.969.559.969.559.97.559.149.149-.336.224-.671.373-.895.522-.97.559-.969.559-.969.559-.636.373-.037 17.748-.187-.075-1.044-.596-.97-.559-.969-.559-.97-.559-.969-.559-.97-.559-.037-.037V8.874l.634-.373.97-.559.969-.559.97-.559.969-.559.895-.522z"></path>
          <path d="M30.686 19.687h.074v7.009l-.634.373-.969.559-.97.559-.969.559-.97.559-.894.522-1.044.597-.895.522-.969.559-.97.559-.969.559-.97.559-.969.559-.97.559-.969.559-.37.149-.932-.522-.634-.373-.97-.559-.969-.559-.97-.559-.895-.522-.037-.075v-7.084l.187.075.932.522.895.522.969.559.97.559.969.559.559.336.559-.299.895-.522.932-.522.634-.373 1.044-.597 1.044-.597 1.044-.597 1.044-.597 1.044-.597.97-.54 1.044-.597 1.044-.597 1.044-.597.895-.522z"></path>
          <path d="M15.362 0l.447.224.895.522.969.559.97.559.969.559.97.559.969.559.895.522 1.044.597.895.522.969.559.97.559.969.559.97.559.97.559.559.336v6.413l-.932.522-.634.373-.969.559-.97.559-.969.559-.97.559-.634.373h-.037l-.037-6.338-1.044-.634-1.193-.708-1.044-.634-.932-.559-1.044-.634-1.193-.708-1.044-.634-1.193-.708-1.044-.634-1.044-.634-1.193-.708-1.044-.597.895-.522.97-.559.969-.559.97-.559.969-.559.97-.559z"></path>
          <path d="M15.324 11.447l.187.037.969.559.97.559.969.559.97.559.969.559.522.298v6.413l-.932.522-.634.373-.969.559-.97.559-.969.559-.97.559-.187-.037-.969-.559-.97-.559-.969-.559-.97-.559-.969-.559-.522-.298v-6.413l.932-.522.895-.522.969-.559.97-.559.969-.559.708-.41z"></path>
          <path d="M9.881 25.317l.186.074.932.522.895.522.969.559.97.559.969.559.559.336.037.037v7.084l-.447-.224-.895-.522-.969-.559-.97-.559-.969-.559-.97-.559-.298-.187v-7.084z"></path>
          <path d="M5.406 5.742l.224.037.969.559.97.559.969.559.97.559.969.559.97.559.149.149-.336.224-.671.373-.895.522-.97.559-.969.559-.969.559-.448-.224-.895-.522-.969-.559-.97-.559-.969-.559-.895-.522L0 8.948v-.112l.932-.522.634-.373.969-.559.97-.559.969-.559.932-.522z"></path>
          <path d="M30.723 8.911h.037v6.376l-.932.522-.634.373-.969.559-.97.559-.969.559-.97.559-.634.373h-.037V12.416l.97-.559.969-.559.97-.559.970-.559.895-.522 1.044-.597.261-.149z"></path>
        </g>
      </svg>
      
      <div style="display:flex;align-items:baseline;gap:4px;width:60px;justify-content:flex-end">
        <span :style="{
            fontSize:'12px', lineHeight:'1.1', fontWeight:700, fontVariantNumeric:'tabular-nums',
            color: processorActive ? '#fff' : 'rgba(255,255,255,0.58)',
            transition:'color 0.3s ease'
          }" x-text="counter.toLocaleString()"></span>
        <span :style="{
            fontSize:'11px', lineHeight:'1', textTransform:'uppercase', letterSpacing:'0.08em',
            color: processorActive ? 'rgba(255,255,255,0.52)' : 'rgba(255,255,255,0.24)',
            transition:'color 0.3s ease'
          }">processed</span>
      </div>
    </div>

    
    <div style="display:flex;flex-direction:row;align-items:center;gap:14px;flex:1">
      
      <div style="width:90px;height:126px;flex-shrink:0;position:relative">
        <template x-for="doc in (processorDoc ? [processorDoc] : [])" :key="docKey">
          <div :style="{
            position:'absolute', top:0, left:'50%', overflow:'hidden',
            background:'#fff',
            borderRadius:'3px',
            boxShadow:'0 2px 8px rgba(0,0,0,0.15), inset 0 0 0 1px ' + doc.border,
            width:'64px', height:'90px',
            transform:'translateX(-50%) scale(1.4)',
            transformOrigin:'top center',
            animation:'docDropIn 0.8s ease-out'
          }">
            <div :style="{ height:'4px', background: doc.color }"></div>
            <div style="position:absolute;top:4px;right:0;width:0;height:0;border-style:solid;border-width:0 9px 9px 0;border-color:transparent rgba(0,132,197,0.08) transparent transparent"></div>
            <div style="padding:5px 5px 6px">
              <div :style="{
                fontSize:'6px', fontWeight:700, color: doc.color,
                whiteSpace:'nowrap', overflow:'hidden', textOverflow:'ellipsis',
                marginBottom:'4px', lineHeight:'8px'
              }" x-text="doc.values[0]"></div>
              <div style="display:flex;flex-direction:column;gap:2px" x-html="doc.skeleton"></div>
            </div>
            
            <template x-if="processorActive">
              <div :style="{
                position:'absolute', left:0, width:'100%', height:'2px',
                background:'linear-gradient(180deg, transparent, #0084C5, transparent)',
                boxShadow:'0 0 8px rgba(0,132,197,0.8)',
                animation:'processorScan 2.2s ease-in-out infinite',
                zIndex:2
              }"></div>
            </template>
          </div>
        </template>
      </div>

      
      <div style="flex:1;min-width:0;height:90px;position:relative">
        <div style="position:absolute;top:0;left:0;right:0;bottom:-40px;overflow:hidden">
          <div style="height:100px;display:flex;align-items:center">
            <div :style="{
              display:'flex', flexDirection:'column', justifyContent:'center', gap:'9px',
              width:'100%',
              animation: dataLeaving ? 'dataSlideOut 0.8s ease-in forwards' : 'none'
            }">
              <template x-for="(field, fi) in fieldConfigs" :key="dataKey + '-' + fi">
                <div :style="{
                  display:'flex', alignItems:'center', justifyContent:'space-between',
                  width:'100%',
                  animation: revealCount > fi ? 'dataCrossfade 0.35s ease forwards' : 'none',
                  opacity: revealCount > fi ? 1 : 0
                }">
                  <div style="display:flex;align-items:center;gap:5px;min-width:0;flex:1">
                    <span style="display:flex;align-items:center;width:16px;height:16px;flex-shrink:0" x-html="fieldIcon(field.iconType)"></span>
                    <span style="font-size:11px;line-height:16px;color:rgba(255,255,255,0.7);white-space:nowrap" x-text="field.label"></span>
                  </div>
                  <span style="font-size:12px;font-weight:600;color:#fff;font-variant-numeric:tabular-nums;letter-spacing:0.01em;text-align:right;flex-shrink:0" x-text="dataValues[fi] || ''"></span>
                </div>
              </template>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  
  <div :style="{
    display:'flex',
    justifyContent:'center',
    alignItems:'center',
    width:'100%',
    height:'24px',
    position:'relative',
    overflow:'hidden'
  }">
    <div style="position:absolute;top:0;bottom:0;left:50%;width:2px;margin-left:-1px;background:rgba(255,255,255,0.14)"></div>
    <div :style="{
      position:'absolute',
      top:0,
      left:'50%',
      width:'2px',
      height:'44%',
      marginLeft:'-1px',
      borderRadius:'999px',
      background:'linear-gradient(180deg, transparent, ' + exportDestinations[activeDestinationIndex].color + ', transparent)',
      opacity: exportSending ? 1 : 0,
      animation: exportSending ? 'exportPipeBeam 0.9s linear infinite' : 'none'
    }"></div>
  </div>

  
  <div :style="{
    width:'100%',
    height:'80px',
    borderRadius:'12px',
    padding:'0 16px',
    display:'flex',
    alignItems:'center',
    gap:'12px',
    background: (exportSending || exportDelivered) ? exportDestinations[activeDestinationIndex].color + '22' : 'rgba(255,255,255,0.04)',
    border: (exportSending || exportDelivered) ? '1px solid ' + exportDestinations[activeDestinationIndex].color + '66' : '1px solid rgba(255,255,255,0.08)',
    boxShadow: exportSending ? '0 0 24px ' + exportDestinations[activeDestinationIndex].color + '33' : (exportDelivered ? '0 0 18px ' + exportDestinations[activeDestinationIndex].color + '22' : 'none'),
    transition:'background 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease',
    animation: (exportSending || exportDelivered) ? 'boxPulse 1s ease-in-out infinite' : 'none'
  }">
    <span :style="{
      width:'30px',
      height:'30px',
      display:'flex',
      alignItems:'center',
      justifyContent:'center',
      flexShrink:0,
      opacity: (exportSending || exportDelivered) ? 1 : 0.72,
      transition:'opacity 0.3s ease'
    }" x-html="destinationIconHtml(exportDestinations[activeDestinationIndex])"></span>

    <div style="min-width:0;display:flex;flex-direction:column;gap:3px">
      <span :style="{
        fontSize:'15px',
        lineHeight:'1.1',
        fontWeight:700,
        color: (exportSending || exportDelivered) ? '#fff' : 'rgba(255,255,255,0.58)',
        transition:'color 0.3s ease'
      }" x-text="exportDestinations[activeDestinationIndex].label"></span>
      <span :style="{
        fontSize:'10px',
        lineHeight:'1',
        color: (exportSending || exportDelivered) ? 'rgba(255,255,255,0.52)' : 'rgba(255,255,255,0.24)',
        textTransform:'uppercase',
        letterSpacing:'0.08em',
        transition:'color 0.3s ease'
      }" x-text="exportDestinations[activeDestinationIndex].kind"></span>
    </div>

    <template x-if="exportSending">
      <span style="margin-left:auto;font-size:11px;font-weight:700;color:#fff;animation:heroBlink 0.6s ease-in-out infinite" x-text="exportStatusText('sending')"></span>
    </template>
    <template x-if="exportDelivered &amp;&amp; !exportSending">
      <span style="margin-left:auto;display:flex;align-items:center;gap:4px;font-size:11px;font-weight:700;color:#fff;animation:exportStatusIn 0.3s ease both">
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
          <path d="M2 5l2.5 2.5 3.5-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        <span x-text="exportStatusText('delivered')"></span>
      </span>
    </template>
  </div>
</div>

<script>
  function heroAnimation(data) {
    var fieldIcons = {
      building: '<svg width="16" height="16" viewBox="0 0 11 11" fill="none"><rect x="1" y="3" width="9" height="7.5" rx="0.8" stroke="rgba(255,255,255,0.45)" stroke-width="1"/><rect x="3" y="5" width="1.5" height="1.5" rx="0.3" fill="rgba(255,255,255,0.45)"/><rect x="6.5" y="5" width="1.5" height="1.5" rx="0.3" fill="rgba(255,255,255,0.45)"/><rect x="3" y="7.5" width="1.5" height="1.5" rx="0.3" fill="rgba(255,255,255,0.45)"/><rect x="6.5" y="7.5" width="1.5" height="1.5" rx="0.3" fill="rgba(255,255,255,0.45)"/><path d="M3.5 3V1.5h4V3" stroke="rgba(255,255,255,0.45)" stroke-width="1"/></svg>',
      hash: '<svg width="16" height="16" viewBox="0 0 11 11" fill="none"><line x1="3.5" y1="1.5" x2="2.5" y2="9.5" stroke="rgba(255,255,255,0.45)" stroke-width="1" stroke-linecap="round"/><line x1="7" y1="1.5" x2="6" y2="9.5" stroke="rgba(255,255,255,0.45)" stroke-width="1" stroke-linecap="round"/><line x1="1" y1="4" x2="9.5" y2="4" stroke="rgba(255,255,255,0.45)" stroke-width="1" stroke-linecap="round"/><line x1="0.5" y1="7" x2="9" y2="7" stroke="rgba(255,255,255,0.45)" stroke-width="1" stroke-linecap="round"/></svg>',
      dollar: '<svg width="16" height="16" viewBox="0 0 11 11" fill="none"><circle cx="5.5" cy="5.5" r="4.5" stroke="rgba(255,255,255,0.45)" stroke-width="1"/><path d="M5.5 2.5v6M3.5 4a2 2 0 0 1 4 0c0 1.5-4 1.5-4 3a2 2 0 0 0 4 0" stroke="rgba(255,255,255,0.45)" stroke-width="1" stroke-linecap="round"/></svg>',
      calendar: '<svg width="16" height="16" viewBox="0 0 11 11" fill="none"><rect x="1" y="2.5" width="9" height="8" rx="0.8" stroke="rgba(255,255,255,0.45)" stroke-width="1"/><line x1="1" y1="5" x2="10" y2="5" stroke="rgba(255,255,255,0.45)" stroke-width="1"/><line x1="3.5" y1="1" x2="3.5" y2="4" stroke="rgba(255,255,255,0.45)" stroke-width="1" stroke-linecap="round"/><line x1="7.5" y1="1" x2="7.5" y2="4" stroke="rgba(255,255,255,0.45)" stroke-width="1" stroke-linecap="round"/><rect x="3" y="6.5" width="1.5" height="1.5" rx="0.3" fill="rgba(255,255,255,0.45)"/><rect x="6.5" y="6.5" width="1.5" height="1.5" rx="0.3" fill="rgba(255,255,255,0.45)"/></svg>'
    };

    // ── Randomization ─────────────────────────────────────────────────────
    var COMPANY_NAMES = [
      'Acme',
      'Nexus',
      'Summit',
      'Vektor',
      'Solaris',
      'Brightpath',
      'DataFlow',
      'GlobalTech',
      'Orion',
      'Kanto',
      'Zephyr',
      'Meridian'
    ];
    var COMPANY_SUFFIXES = [
      'Corp',
      'Inc',
      'Ltd',
      'LLC',
      'SA',
      'SAS',
      'GmbH',
      'AG',
      'Pty Ltd',
      'Co'
    ];
    var INVOICE_PREFIXES = [
      'INV',
      'NDA',
      'PO',
      'RCT',
      'SO',
      'QT',
      'EST',
      'CN'
    ];
    var CURRENCIES = [
      '$',
      '\u20AC',
      '\u00A3',
      '\u00A5',
      'CHF\u00A0',
      'A$'
    ];
    var DOC_COLORS = [
      {
        color: '#0084C5',
        bg: 'rgba(0,132,197,0.08)',
        border: 'rgba(0,132,197,0.15)'
      }, {
        color: '#006fa8',
        bg: 'rgba(0,111,168,0.08)',
        border: 'rgba(0,111,168,0.15)'
      }, {
        color: '#0079B9',
        bg: 'rgba(0,121,185,0.08)',
        border: 'rgba(0,121,185,0.15)'
      }, {
        color: '#003854',
        bg: 'rgba(0,56,84,0.08)',
        border: 'rgba(0,56,84,0.25)'
      }, {
        color: '#004160',
        bg: 'rgba(0,65,96,0.08)',
        border: 'rgba(0,65,96,0.25)'
      }
    ];

    var docIdCounter = 0;
    function pick(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function randomAmount() {
      var amount = (Math.random() * 24750 + 250).toFixed(2);
      var parts = amount.split('.');
      parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      return pick(CURRENCIES) + parts.join('.');
    }

    function randomDate() {
      var now = Date.now();
      var oneYearAgo = now - 365 * 24 * 60 * 60 * 1000;
      var d = new Date(oneYearAgo + Math.random() * (now - oneYearAgo));
      var yyyy = d.getFullYear();
      var mm = String(d.getMonth() + 1).padStart(2, '0');
      var dd = String(d.getDate()).padStart(2, '0');
      return yyyy + '-' + mm + '-' + dd;
    }

    function randomInvoiceNum() {
      var prefix = pick(INVOICE_PREFIXES);
      var num = String(Math.floor(Math.random() * 900) + 100);
      return prefix + '-2025-' + num;
    }

    // Helper: a single skeleton line
    var g = 'rgba(0,56,84,0.25)';
    var g2 = 'rgba(0,132,197,0.15)';
    var g3 = 'rgba(0,132,197,0.08)';
    function ln(w, bg) {
      return '<div style="height:1.5px;width:' + w + ';border-radius:9999px;background:' + (
      bg || g2) + '"></div>';
    }
    function gap(h) {
      return '<div style="height:' + (
      h || 2) + 'px"></div>';
    }
    // Table row: 2 or 3 columns
    function trow(cols, bg) {
      var cells = '';
      for (var i = 0; i < cols; i++)
        cells += '<div style="height:1.5px;flex:' + (
          i === 0
          ? 2
          : 1) + ';border-radius:9999px;background:' + (
        bg || g2) + '"></div>';
      return '<div style="display:flex;gap:2px">' + cells + '</div>';
    }

    // Invoice skeleton generators - each builds a unique layout
    var SKELETON_LAYOUTS = [
      // Layout A: Logo top-right, address block, table, total
      function (c) {
        return '<div style="display:flex;justify-content:space-between;align-items:flex-start">' + '<div style="display:flex;flex-direction:column;gap:1.5px">' + ln('70%', g) + ln('55%', g3) + ln('60%', g3) + '</div>' + '<div style="width:8px;height:6px;border-radius:1px;background:' + c + '30"></div></div>' + gap(3) + ln('40%', c + '33') + gap(1) + '<div style="height:0.5px;width:100%;background:' + g + '"></div>' + trow(3, g) + trow(3, g3) + trow(3, g3) + trow(3, g3) + '<div style="height:0.5px;width:100%;background:' + g + '"></div>' + '<div style="display:flex;justify-content:flex-end">' + ln('35%', c + '44') + '</div>';
      },
      // Layout B: Centered logo, two address columns, table, total right
      function (c) {
        return '<div style="display:flex;justify-content:center"><div style="width:10px;height:5px;border-radius:1px;background:' + c + '30"></div></div>' + gap(2) + '<div style="display:flex;gap:4px"><div style="flex:1;display:flex;flex-direction:column;gap:1.5px">' + ln('90%', g) + ln('70%', g3) + '</div>' + '<div style="flex:1;display:flex;flex-direction:column;gap:1.5px;align-items:flex-end">' + ln('80%', g) + ln('60%', g3) + '</div></div>' + gap(3) + '<div style="height:0.5px;width:100%;background:' + g + '"></div>' + trow(2, g) + trow(2, g3) + trow(2, g3) + trow(2, g3) + trow(2, g3) + '<div style="height:0.5px;width:100%;background:' + g + '"></div>' + '<div style="display:flex;justify-content:flex-end;gap:2px">' + ln('20%', g3) + ln('25%', c + '44') + '</div>';
      },
      // Layout C: Logo top-left, invoice meta right, wide table, totals
      function (c) {
        return '<div style="display:flex;justify-content:space-between;align-items:flex-start">' + '<div style="width:12px;height:6px;border-radius:1px;background:' + c + '30"></div>' + '<div style="display:flex;flex-direction:column;gap:1.5px;align-items:flex-end">' + ln('60%', g) + ln('45%', g3) + '</div></div>' + gap(2) + ln('50%', g3) + ln('40%', g3) + gap(3) + trow(3, c + '22') + trow(3, g3) + trow(3, g3) + '<div style="height:0.5px;width:100%;background:' + g + '"></div>' + trow(3, g3) + '<div style="display:flex;justify-content:flex-end">' + ln('30%', c + '44') + '</div>';
      },
      // Layout D: No logo, large title line, address, short table, signature
      function (c) {
        return ln('65%', c + '44') + gap(2) + ln('80%', g) + ln('60%', g3) + ln('70%', g3) + gap(3) + ln('90%', g) + ln('85%', g3) + ln('75%', g3) + gap(2) + '<div style="height:0.5px;width:100%;background:' + g + '"></div>' + trow(2, g) + trow(2, g3) + trow(2, g3) + '<div style="height:0.5px;width:100%;background:' + g + '"></div>' + gap(2) + '<div style="display:flex;justify-content:flex-end">' + ln('30%', g) + '</div>';
      },
      // Layout E: Two-column header, reference lines, big table, double total
      function (c) {
        return '<div style="display:flex;gap:4px"><div style="flex:1;display:flex;flex-direction:column;gap:1.5px">' + ln('100%', g) + ln('70%', g3) + ln('55%', g3) + '</div>' + '<div style="flex:1;display:flex;flex-direction:column;gap:1.5px;align-items:flex-end">' + ln('50%', c + '33') + ln('60%', g3) + '</div></div>' + gap(3) + '<div style="height:0.5px;width:100%;background:' + c + '22"></div>' + trow(3, g) + trow(3, g3) + trow(3, g3) + trow(3, g3) + trow(3, g3) + '<div style="height:0.5px;width:100%;background:' + c + '22"></div>' + '<div style="display:flex;justify-content:flex-end;flex-direction:column;align-items:flex-end;gap:1.5px">' + ln('35%', g3) + ln('35%', c + '44') + '</div>';
      }
    ];

    var lastColorIdx = -1;

    function generateDoc() {
      // Pick a color different from the previous one
      var colorIdx;
      do {
        colorIdx = Math.floor(Math.random() * DOC_COLORS.length);
      } while (colorIdx === lastColorIdx);
      lastColorIdx = colorIdx;
      var palette = DOC_COLORS[colorIdx];

      var layoutFn = SKELETON_LAYOUTS[Math.floor(Math.random() * SKELETON_LAYOUTS.length)];

      docIdCounter++;
      return {
        id: docIdCounter,
        color: palette.color,
        bg: palette.bg,
        border: palette.border,
        skeleton: layoutFn(palette.color),
        values: [
          pick(COMPANY_NAMES) + ' ' + pick(COMPANY_SUFFIXES),
          randomInvoiceNum(),
          randomAmount(),
          randomDate()
        ]
      };
    }

    // Generate initial belt queue (no consecutive same colors)
    function initialBelt() {
      var docs = [];
      for (var i = 0; i < 8; i++)
        docs.push(generateDoc());
      return docs;
    }

    return {
      // ── State ───────────────────────────────────────────────────────────
      beltDocs: [],
      beltOffset: 0,
      beltTransition: 'none',
      droppingDoc: null,
      processorDoc: null,
      processorActive: false,
      dataValues: [],
      dataKey: 0,
      docKey: 0,
      revealCount: 0,
      counter: 0,
      activeDestinationIndex: 0,
      nextDestinationIndex: 0,
      dataLeaving: false,
      exportSending: false,
      exportDelivered: false,
      _timers: [],

      // ── Static config ───────────────────────────────────────────────────
      fieldConfigs: [
        { iconType: 'building', label: data.fieldLabels[0] },
        { iconType: 'hash',     label: data.fieldLabels[1] },
        { iconType: 'dollar',   label: data.fieldLabels[2] },
        { iconType: 'calendar', label: data.fieldLabels[3] },
      ],

      exportDestinations: (function () {
        var k = data.destinationKinds;
        return [
          { label: 'Google Sheets',  action: 'send',     kind: k.spreadsheet, color: '#0F9D58', src: '/images/apps/sheets.png' },
          { label: 'Zapier',         action: 'send',     kind: k.automation,  color: '#FF4A00', src: '/images/apps/zapier.png' },
          { label: 'Excel',          action: 'download', kind: k.download,    color: '#217346', src: '/images/apps/excel.png' },
          { label: 'Make',           action: 'send',     kind: k.automation,  color: '#6D5BD0', src: '/images/apps/make.svg' },
          { label: 'Webhook',        action: 'send',     kind: k.customApp,   color: '#F3F4F6', src: '/images/apps/webhook.svg' },
          { label: 'Power Automate', action: 'send',     kind: k.automation,  color: '#0066FF', src: '/images/apps/power-automate.png' },
        ];
      }()),

      // ── Helpers ──────────────────────────────────────────────────────────
      fieldIcon: function (type) {
        return fieldIcons[type] || '';
      },
      destinationIconHtml: function (dest) {
        if (!dest || !dest.src)
          return '';
        return '<img src="' + dest.src + '" alt="" style="width:24px;height:24px;display:block;object-fit:contain" loading="eager">';
      },
      exportStatusText: function (state) {
        var dest = this.exportDestinations[this.activeDestinationIndex];
        if (dest && dest.action === 'download')
          return state === 'sending' ? data.statusLabels.downloading + '...' : data.statusLabels.downloaded;
        return state === 'sending' ? data.statusLabels.sending + '...' : data.statusLabels.delivered;
      },
      runExportAnimation: function () {
        var self = this;
        var START_DELAY = 160;
        var SEND_DURATION = 1180;
        var DELIVERED_HOLD = 980;
        var EXPORT_DURATION = START_DELAY + SEND_DURATION + DELIVERED_HOLD;

        if (this.dataValues.length === 0)
          return 0;

        this.dataLeaving = true;
        this.exportSending = false;
        this.exportDelivered = false;

        this.after(function () {
          self.exportSending = true;
        }, START_DELAY);

        this.after(function () {
          self.exportSending = false;
          self.exportDelivered = true;
        }, START_DELAY + SEND_DURATION);

        this.after(function () {
          self.exportDelivered = false;
          self.dataLeaving = false;
          self.dataValues = [];
          self.revealCount = 0;
          self.dataKey++;
        }, EXPORT_DURATION);

        return EXPORT_DURATION;
      },
      after: function (fn, ms) {
        this
          ._timers
          .push(setTimeout(fn, ms));
      },

      // ── Animation ───────────────────────────────────────────────────────
      start: function () {
        this.counter = Math.floor(Math.random() * 3000) + 12000;
        this.beltDocs = initialBelt();
        this.activeDestinationIndex = 0;
        this.nextDestinationIndex = 0;
        this.pipelineTick();
      },

      pipelineTick: function () {
        var self = this;
        var STEP = 80; // 64px doc + 16px gap
        var DROP_DURATION = 800;
        var SCAN_FIELD_DELAY = 350;
        var POST_SCAN_DELAY = (self.fieldConfigs.length * SCAN_FIELD_DELAY) + 200;
        var frontDoc = this.beltDocs.length > 0
          ? this.beltDocs[0]
          : null;

        // ═══ PHASE 1 (0ms): Drop next doc into the processor ═══
        if (frontDoc) {
          this.activeDestinationIndex = this.nextDestinationIndex;
          this.nextDestinationIndex = (this.nextDestinationIndex + 1) % this.exportDestinations.length;
          this.droppingDoc = frontDoc;
          this.processorDoc = frontDoc;
          this.processorActive = false;
          this.docKey++;
        }
        this.beltTransition = 'transform ' + DROP_DURATION + 'ms linear';
        this.beltOffset = -STEP;

        // ═══ PHASE 2 (800ms): Drop landed. Start scanning + reveal fields ═══
        this.after(function () {
          // Clean up belt in one frame
          self.beltTransition = 'none';
          requestAnimationFrame(function () {
            self.droppingDoc = null;
            self.beltDocs = self
              .beltDocs
              .slice(1)
              .concat([generateDoc()]);
            self.beltOffset = 0;
          });

          // Set new data, start scanning and reveal fields
          if (frontDoc) {
            self.dataValues = frontDoc.values;
            self.revealCount = 0;
            self.dataKey++;
            self.processorActive = true;

            self
              .fieldConfigs
              .forEach(function (_, fi) {
                self.after(function () {
                  self.revealCount = fi + 1;
                }, fi * SCAN_FIELD_DELAY);
              });

            // After all fields revealed: stop scan, then export before next tick
            self.after(function () {
              self.processorActive = false;
              self.counter++;

              var exportDuration = self.runExportAnimation();
              self.after(function () {
                self.pipelineTick();
              }, exportDuration);
            }, POST_SCAN_DELAY);
          }
        }, DROP_DURATION);
      }
    };
  }
</script>

    </div>
  </section>
  
  <div class="flex flex-col gap-4">
    <p class="mx-auto max-w-3xl px-4 text-center text-base leading-8 text-gray-700 sm:text-xl lg:text-lg"></p>
    <div class="my-4 overflow-hidden" x-data="companyLogoCarousel()" x-init="init()">
  <div class="logo-carousel-wrapper">
    <div class="logo-carousel-track scrolling" x-ref="track" :style="`--duration: ${duration}s`">
      <template x-for="img in doubledLogos" :key="img.id">
        <img :src="'/images/company_logos/' + img.src" :alt="img.alt" :title="img.alt" loading="eager" width="160" height="36">
      </template>
    </div>
  </div>
</div>

<script>
  function companyLogoCarousel() {
    return {
      duration: 0,
      allLogos: [
        { src: "dun_and_bradstreet.svg", alt: "Dun & Bradstreet" },
        { src: "coca-cola.svg", alt: "Coca-Cola" },
        { src: "intertek.svg", alt: "Intertek" },
        { src: "cushman_and_wakefield.png", alt: "Cushman & Wakefield" },
        { src: "gartner.svg", alt: "Gartner" },
        { src: "panini.png", alt: "Panini" },
        { src: "isaca.png", alt: "ISACA" },
        { src: "world_wide_technology.png", alt: "World Wide Technology" },
        { src: "swagelok.png", alt: "Swagelok" },
        { src: "dormakaba.svg", alt: "Dormakaba" },
        { src: "handm.svg", alt: "H&M" },
        { src: "savills.svg", alt: "Savills" },
        { src: "johns_hopkins.png", alt: "Johns Hopkins" },
        { src: "adecco.svg", alt: "Adecco Group" },
        { src: "podium.png", alt: "Podium" },
        { src: "nippon_gases.svg", alt: "Nippon Gases" },
        { src: "am_best.svg", alt: "AM Best" },
        { src: "clio.svg", alt: "Clio" },
        { src: "compass_inc.svg", alt: "Compass" },
        { src: "cox_automotive.svg", alt: "Cox Automotive" },
        { src: "decathlon.svg", alt: "Decathlon" },
        { src: "van_leeuwen.png", alt: "Van Leeuwen" },
        { src: "us_olympic_committee.svg", alt: "US Olympic Committee" },
        { src: "manulife.svg", alt: "Manulife" },
        { src: "keller_williams.svg", alt: "Keller Williams" },
        { src: "celigo.png", alt: "Celigo" },
        { src: "beyond_meat.png", alt: "Beyond Meat" },
        { src: "spie.png", alt: "SPIE" },
        { src: "engel_and_volkers.png", alt: "Engel & Völkers" },
        { src: "stout.png", alt: "Stout" },
        { src: "pennymac.svg", alt: "PennyMac" },
        { src: "f45_training.svg", alt: "F45 Training" },
        { src: "jobandtalent.svg", alt: "Job&talent" },
        { src: "socotec.png", alt: "Socotec" },
        { src: "homeday.svg", alt: "Homeday.de" },
        { src: "kraftanlagen.svg", alt: "Kraftanlagen" },
        { src: "rxsight.svg", alt: "RxSight" },
        { src: "proliant.png", alt: "Proliant" },
        { src: "hungerrush.png", alt: "HungerRush" },
        { src: "puleva.jpg", alt: "Puleva" },
      ],
      doubledLogos: [],

      init() {
        // Rotate so the first logos in the list appear in the center of the viewport on load.
        // Put just enough tail logos before the first one to fill the left half of the screen.
        const offset = Math.ceil(window.innerWidth / 2 / 224) // ~224px per logo (160px max + 64px gap)
        const rotated = [...this.allLogos.slice(-offset), ...this.allLogos.slice(0, -offset)]
        this.doubledLogos = [...rotated.map((l, i) => ({ ...l, id: "a" + i })), ...rotated.map((l, i) => ({ ...l, id: "b" + i }))]
        this.duration = Math.round(this.allLogos.length * 4.4)
      },
    }
  }
</script>

