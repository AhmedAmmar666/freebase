<script>
function hiwDefineAnimation(data) {
  const REGIONS = ['header-right', 'header-left', 'header-date', 'table', 'total'];
  const FIELDS  = data.fieldLabels.map((lbl, i) => ({ label: lbl, region: REGIONS[i] }));
  return {
    active: -1,
    done: [],
    fields: FIELDS,
    counterSuffix: data.counterSuffix,
    _timers: [],
    label(region) {
      const f = FIELDS.find(f => f.region === region);
      return f ? f.label : '';
    },
    isActive(region) {
      return this.active >= 0 && FIELDS[this.active].region === region;
    },
    isDone(region) {
      return this.done.some(i => FIELDS[i] && FIELDS[i].region === region);
    },
    clear() { this._timers.forEach(clearTimeout); this._timers = []; },
    after(fn, ms) { this._timers.push(setTimeout(fn, ms)); },
    start() { this.cycle(); },
    cycle() {
      this.clear();
      this.active = -1;
      this.done = [];
      const self = this;
      let i = 0;
      const tick = () => {
        if (i >= FIELDS.length) {
          self.active = -1;
          self.after(() => window.dispatchEvent(new CustomEvent('hiw-done')), 2200);
          return;
        }
        self.active = i;
        self.done = [...self.done, i];
        i++;
        self.after(tick, 800);
      };
      self.after(tick, 600);
    },
  };
}
</script>

