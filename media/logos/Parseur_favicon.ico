                    <div class="flex flex-col ">
                        <p class="uppercase text-gray-500 text-xs tracking-widest font-medium mb-4">Core features</p>
                        <a href="/" class="group flex items-start gap-3 rounded-lg hover:bg-blue-50 transition ease-in-out duration-150 px-2 py-2.5 ">
                            <div class="flex-shrink-0 bg-blue-50 group-hover:bg-blue-100 rounded-lg text-brand w-9 h-9 flex items-center justify-center transition ease-in-out duration-150">
                              <i class="far fa-user-robot text-sm"></i>
                            </div>
                            <div class="pt-0.5">
                              <p class="text-sm font-semibold text-gray-900 group-hover:text-brand leading-snug transition ease-in-out duration-150">AI-based data extraction</p>
                              <p class="mt-0.5 text-xs text-gray-500 leading-snug">Parse documents using artificial intelligence</p>
                            </div>
