          <span class="ml-1">日本語</span>
        </a>
      
    
      
        <a href="/ko/" @click="psrSetLang('ko')" role="menuitem" id="menu-item-한국어" class="group flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 hover:text-gray-900">
